{
  "name": "project-name-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "description": "Monorepo of project-name",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --cache --write .",
    "release": "bumpp -r && pnpm publish -r",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@sxzz/eslint-config": "^8.0.0",
    "@sxzz/prettier-config": "^2.3.1",
    "@types/node": "^24.12.2",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "publint": "^0.3.18",
    "tsdown": "^0.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "prettier": "@sxzz/prettier-config"
}
